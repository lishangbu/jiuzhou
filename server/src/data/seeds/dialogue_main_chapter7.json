{
  "dialogues": [
    {
      "id": "dlg-main-7-001",
      "name": "第七章-001 镜墟初临",
      "nodes": [
        {
          "id": "start",
          "type": "narration",
          "text": "界桥尽头，整片镜墟像一面被大道掰裂的明镜。\n所有灵压都被折成细碎的回光，连呼吸都像在被审视。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "引镜使",
          "text": "这里不是比谁伤害更高，而是比谁更懂得收手。\n镜墟会把你最急躁的一击原样奉还。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "引镜使",
          "text": "先去折光外环清掉镜甲卫侍与折光灵官，学会看清它们的返照窗口，再谈后面的问律。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：击败镜甲卫侍与折光灵官。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-7-002",
      "name": "第七章-002 折光清障",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "引镜使",
          "text": "你已经看懂外环的节奏了。\n真正的问律不在野外，而在玄鉴司天宫，那里的镜律会主动逼你犯错。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "引镜使",
          "text": "去司天宫门找问律师，先通过普通问律，再回来谈合道契印。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：通关玄鉴司天宫普通难度。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-7-003",
      "name": "第七章-003 玄宫试律",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "问律师",
          "text": "你能从普通问律里活着走出来，说明你已学会不和镜界硬碰硬。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "问律师",
          "text": "但合道不是会躲就够，还要能把自己的道印铸得足够稳。\n去找铸印道人，先把道镜玄砂收齐。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集道镜玄砂16个，并向铸印道人复命。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-7-004",
      "name": "第七章-004 道砂归炉",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "铸印道人",
          "text": "玄砂足够了，但契印还缺最后一道真纹。\n你得去困难司天宫，把玄鉴真君的主镜潮压下来。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "铸印道人",
          "text": "他最强的时候反照最凶，可一旦节奏被你拆开，镜律也会露出破绽。\n完成两轮困难问律，再回来见我。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：通关玄鉴司天宫困难2次，并击败玄鉴真君1次。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-7-005",
      "name": "第七章-005 司天破镜",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "铸印道人",
          "text": "主镜潮已经被你压住，契印的骨架也终于稳了。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "铸印道人",
          "text": "接下来只差把足量契印聚齐，交给问律师做最后一道照真审定。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集合道契印4个，并向问律师复命。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-7-006",
      "name": "第七章-006 契印合道",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "问律师",
          "text": "四枚契印律纹一致，足以让你的神识与镜律完成最后的校频。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "问律师",
          "text": "从此你面对的不再只是外物反噬，而是自己的道与天地是否同鸣。\n去准备突破吧，合道之门已经向你显出轮廓。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "问律师",
          "text": "当你再次踏入镜墟时，便不只是被审视者，而会是能够回照天地的人。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "第七章完成：合道照真。已满足还虚突破合道主线前置。"
        }
      ],
      "enabled": true
    }
  ]
}
