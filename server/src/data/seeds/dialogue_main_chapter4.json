{
  "dialogues": [
    {
      "id": "dlg-main-4-001",
      "name": "第四章-001 沼地前哨",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "镇沼使",
          "text": "你来得及时。胎息沼的灵压已开始内卷，再拖下去会反噬经脉。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：稳定前哨并展开清剿。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-002",
      "name": "第四章-002 泥潮清剿",
      "nodes": [
        {
          "id": "start",
          "type": "narration",
          "text": "泥潮翻涌，异化灵物从沼底不断爬出。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：清剿泥潮区敌群。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-003",
      "name": "第四章-003 胎元采集",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "胎息药师",
          "text": "阵基还缺胎元晶魄与九台精华，先把材料补齐。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：采集胎元晶魄并回收九台精华。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-004",
      "name": "第四章-004 入宫阙",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "镇沼使",
          "text": "阵门已稳。去九台宫阙外门找隐修者，他会带你过第一道关。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：抵达宫阙外门并与九台隐修者交谈。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-005",
      "name": "第四章-005 宫阙初试",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "九台隐修者",
          "text": "先过普通试炼，熟悉阵核节奏。能稳住气机，再谈压测。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：通关九台宫阙（普通）。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-006",
      "name": "第四章-006 七层归一",
      "nodes": [
        {
          "id": "start",
          "type": "narration",
          "text": "功法未至七层，胎元无法稳固成形。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：将任意天阶功法提升至第七层。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-007",
      "name": "第四章-007 宫阙压测",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "九台隐修者",
          "text": "困难强度才是真正门槛。扛住它，你才有资格结胎。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：通关九台宫阙（困难）。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-008",
      "name": "第四章-008 结胎筹备",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "九台隐修者",
          "text": "压测已过，接下来把突破材料一次备齐。晶魄与结胎丹，缺一不可。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集胎元晶魄 12 份与结胎丹 3 份。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-4-009",
      "name": "第四章-009 破关前夜",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "九台隐修者",
          "text": "材料与阵序都已完备。第四章到此收束，你可正式冲击结胎。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "第四章完成：胎息初成。已满足结胎突破主线前置。"
        }
      ],
      "enabled": true
    }
  ]
}
