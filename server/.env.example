# 数据库配置
DB_HOST=localhost
DB_PORT=6060
DB_NAME=jiuzshou_s
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_LOG=false

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=6011
NODE_ENV=development

# 跨域配置
CORS_ORIGIN="http://localhost:6010"

# 腾讯云 COS 配置（头像上传）
# 未配置时自动回退本地磁盘存储
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"
COS_AVATAR_PREFIX="avatars/"
# 自定义域名（不含协议和末尾 /），例如 oss.example.com
# 配置后头像 URL 会使用此域名，未配置则使用 COS 默认域名
COS_DOMAIN=""